/* components/dishPicker/dishPicker.wxss */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  transition: background 0.3s ease;
}

.picker-mask.show {
  background: rgba(0, 0, 0, 0.5);
}

.picker-container {
  width: 100%;
  max-height: 75vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.picker-container.slide-up {
  transform: translateY(0);
}

.picker-container.slide-down {
  transform: translateY(100%);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.picker-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.picker-search {
  padding: 20rpx 30rpx;
}

.picker-search-input {
  height: 68rpx;
  background: #f5f5f5;
  border-radius: 34rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.picker-list {
  flex: 1;
  max-height: 55vh;
  padding: 0 0 20rpx;
}

.picker-loading,
.picker-empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  margin: 0;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.15s;
}

.picker-item:active {
  background: #f0f9f0;
}

.picker-item-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.picker-item-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.picker-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.picker-item-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.picker-item-count {
  font-size: 22rpx;
  color: #999;
}

/* 添加按钮 */
.picker-add-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: transparent;
  border: 2rpx solid #4CAF50;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.picker-item:active .picker-add-btn {
  background: #e8f5e9;
}

.add-icon {
  color: #4CAF50;
  font-size: 32rpx;
  font-weight: normal;
  line-height: 48rpx;
  margin-top: -2rpx;
}
