/* components/dishPicker/dishPicker.wxss */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.picker-container {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.picker-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.picker-search {
  padding: 20rpx 30rpx;
}

.picker-search-input {
  height: 68rpx;
  background: #f5f5f5;
  border-radius: 34rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.picker-list {
  flex: 1;
  max-height: 50vh;
  padding: 0;
}

.picker-loading,
.picker-empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  margin: 0;
  padding: 20rpx 30rpx 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  border-left: 6rpx solid transparent;
  transition: background-color 0.2s;
}

.picker-item.checked {
  background: #E8F5E9;
  border-left-color: #4CAF50;
  border-bottom: 1rpx solid #C8E6C9;
}

.picker-item.checked .picker-item-name {
  color: #2E7D32;
  font-weight: bold;
}

.custom-checkbox {
  width: 40rpx;
  height: 40rpx;
  min-width: 40rpx;
  border: 3rpx solid #ccc;
  border-radius: 8rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.custom-checkbox.checked {
  background: #4CAF50;
  border-color: #4CAF50;
}

.check-icon {
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  line-height: 1;
}

.picker-item-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.picker-item-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.picker-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.picker-item-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.picker-item-count {
  font-size: 22rpx;
  color: #999;
}

.picker-footer {
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}

.picker-confirm-btn {
  width: 100%;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #4CAF50 !important;
  color: #fff !important;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  padding: 0;
}

.picker-confirm-btn::after {
  border: none;
}
