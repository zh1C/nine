<!--components/dishPicker/dishPicker.wxml-->
<view class="picker-mask {{show ? 'show' : ''}}" wx:if="{{visible}}" bindtap="handleClose">
  <view class="picker-container {{show ? 'slide-up' : 'slide-down'}}" catchtap="preventBubble">
    <view class="picker-header">
      <text class="picker-title">添加菜品</text>
      <text class="picker-close" bindtap="handleClose">✕</text>
    </view>

    <view class="picker-search">
      <input
        class="picker-search-input"
        placeholder="🔍 搜索菜品名..."
        value="{{keyword}}"
        bindinput="onInputSearch"
        bindconfirm="handleSearch"
      />
    </view>

    <scroll-view class="picker-list" scroll-y>
      <view wx:if="{{dishes.length === 0}}" class="picker-empty">暂无更多菜品</view>
      <view
        wx:for="{{dishes}}"
        wx:key="_id"
        class="picker-item"
        data-idx="{{index}}"
        bindtap="handleAdd"
      >
        <image
          wx:if="{{item.imageFileID}}"
          class="picker-item-image"
          src="{{item.imageFileID}}"
          mode="aspectFill"
        />
        <view wx:else class="picker-item-placeholder">🍽️</view>
        <view class="picker-item-info">
          <text class="picker-item-name">{{item.name}}</text>
          <text class="picker-item-count">{{item.ingredients.length}}种配料</text>
        </view>
        <view class="picker-add-btn">
          <text class="add-icon">+</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
