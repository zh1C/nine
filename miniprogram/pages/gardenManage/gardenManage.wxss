/* pages/gardenManage/gardenManage.wxss */
.garden-manage-page {
  min-height: 100vh;
  padding: 30rpx;
  background: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.search-btn {
  height: 72rpx;
  padding: 0 30rpx;
  background: #4CAF50;
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-btn {
  height: 72rpx;
  padding: 0 24rpx;
  background: #f0f0f0;
  color: #666;
  font-size: 28rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 新增按钮 */
.add-bar {
  margin-bottom: 24rpx;
}

.add-btn {
  display: inline-flex;
  padding: 16rpx 32rpx;
  background: #4CAF50;
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
}

.add-btn:active {
  opacity: 0.8;
}

/* 园区列表 */
.garden-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.garden-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.garden-info {
  flex: 1;
  overflow: hidden;
}

.garden-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.garden-time {
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.garden-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.edit-btn {
  padding: 12rpx 28rpx;
  background: #e3f2fd;
  color: #1976d2;
  font-size: 26rpx;
  border-radius: 30rpx;
}

.edit-btn:active {
  opacity: 0.7;
}

.delete-btn {
  padding: 12rpx 28rpx;
  background: #ffebee;
  color: #d32f2f;
  font-size: 26rpx;
  border-radius: 30rpx;
}

.delete-btn:active {
  opacity: 0.7;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载中 */
.loading-state {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 弹窗 */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.dialog-box {
  width: 80%;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 30rpx;
  text-align: center;
  color: #333;
}

.dialog-input {
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.dialog-btns {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.dialog-cancel,
.dialog-confirm {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
}

.dialog-cancel {
  background: #f5f5f5;
  color: #666;
}

.dialog-confirm {
  background: #4CAF50;
  color: #fff;
}

.dialog-cancel:active,
.dialog-confirm:active {
  opacity: 0.8;
}
