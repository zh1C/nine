/* pages/dishEdit/dishEdit.wxss */
.dish-edit-page {
  min-height: 100vh;
  padding: 20rpx 30rpx 40rpx;
  background: #f5f5f5;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.image-upload {
  width: 240rpx;
  height: 240rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  background: #f5f5f5;
  border: 2rpx dashed #ccc;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

.name-input {
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  background: #fafafa;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.ingredient-header {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
  margin-bottom: 16rpx;
}

.col-name {
  flex: 3;
  font-size: 24rpx;
  color: #666;
}

.col-ratio {
  flex: 2;
  font-size: 24rpx;
  color: #666;
}

.col-unit {
  flex: 2;
  font-size: 24rpx;
  color: #666;
}

.col-action {
  width: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666;
}

.ingredient-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.ingredient-name {
  flex: 3;
  height: 64rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  margin-right: 12rpx;
  background: #fafafa;
}

.ingredient-ratio {
  flex: 2;
  height: 64rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  margin-right: 12rpx;
  background: #fafafa;
}

.ingredient-unit {
  flex: 2;
  margin-right: 12rpx;
}

.unit-picker {
  height: 64rpx;
  line-height: 64rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  background: #fafafa;
  text-align: center;
}

.remove-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FF5252;
  font-size: 32rpx;
}

.add-ingredient-btn {
  margin-top: 20rpx;
  text-align: center;
  padding: 20rpx;
  border: 1rpx dashed #4CAF50;
  border-radius: 8rpx;
  color: #4CAF50;
  font-size: 28rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #4CAF50 !important;
  color: #fff !important;
  border-radius: 44rpx;
  font-size: 34rpx;
  font-weight: bold;
  margin-top: 20rpx;
  border: none;
}

.save-btn::after {
  border: none;
}
