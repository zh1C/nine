/* pages/dishEdit/dishEdit.wxss */
.dish-edit-page {
  min-height: 100vh;
  padding: 20rpx 30rpx 40rpx;
  background: #f5f5f5;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

/* 图片上传 */
.image-upload {
  width: 240rpx;
  height: 240rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  background: #f5f5f5;
  border: 2rpx dashed #ccc;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

/* 菜品名称 */
.name-input {
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  background: #fafafa;
}

/* 菜品类型选择器 */
.category-selector {
  display: flex;
  gap: 24rpx;
  padding: 16rpx 0;
}

.category-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  background: #fafafa;
  transition: all 0.2s;
}

.category-option.active {
  border-color: #4CAF50;
  background: #e8f5e9;
  box-shadow: 0 2rpx 12rpx rgba(76, 175, 80, 0.15);
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.category-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.category-option.active .category-text {
  color: #2E7D32;
  font-weight: bold;
}

/* 配料列表 */
.ingredient-header {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
  margin-bottom: 16rpx;
}

.col-name {
  flex: 3;
  font-size: 24rpx;
  color: #666;
}

.col-unit {
  flex: 2;
  font-size: 24rpx;
  color: #666;
}

.col-type {
  flex: 2;
  font-size: 24rpx;
  color: #666;
}

.col-advance {
  width: 100rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666;
}

.col-action {
  width: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666;
}

.ingredient-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.ingredient-name {
  flex: 3;
  height: 64rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  margin-right: 12rpx;
  background: #fafafa;
}

.ingredient-unit {
  flex: 2;
  margin-right: 12rpx;
}

.ingredient-type {
  flex: 2;
  margin-right: 12rpx;
}

.type-picker {
  height: 64rpx;
  line-height: 64rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  background: #fafafa;
  text-align: center;
}

.unit-picker {
  height: 64rpx;
  line-height: 64rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  background: #fafafa;
  text-align: center;
}

/* 提前送货复选框 */
.advance-check {
  width: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ccc;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #4CAF50;
  border-color: #4CAF50;
}

.remove-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FF5252;
  font-size: 32rpx;
}

.add-ingredient-btn {
  margin-top: 20rpx;
  text-align: center;
  padding: 20rpx;
  border: 1rpx dashed #4CAF50;
  border-radius: 8rpx;
  color: #4CAF50;
  font-size: 28rpx;
}

.add-ingredient-btn:active {
  opacity: 0.7;
}

/* 园区比例区域 */
.empty-garden-tip {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.garden-section {
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.garden-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx;
  background: #fafafa;
}

.garden-header:active {
  background: #f0f0f0;
}

.garden-header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.garden-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.garden-status {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 16rpx;
}

.garden-status-text {
  font-size: 22rpx;
  line-height: 1;
}

.status-filled {
  background: #e8f5e9;
  color: #388e3c;
}

.status-empty {
  background: #f5f5f5;
  color: #999;
}

.garden-arrow {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
  height: 44rpx;
  line-height: 44rpx;
}

.garden-body {
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #e8e8e8;
}

.ratio-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.ratio-row:last-child {
  margin-bottom: 0;
}

.ratio-label {
  width: 140rpx;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  height: 64rpx;
  line-height: 64rpx;
}

.ratio-input {
  flex: 1;
  height: 64rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  background: #fafafa;
  margin: 0 12rpx;
}

.ratio-unit {
  width: 60rpx;
  font-size: 24rpx;
  color: #666;
  height: 64rpx;
  line-height: 64rpx;
}

.advance-tag {
  margin-left: 8rpx;
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
}

/* 保存按钮 */
.save-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #4CAF50 !important;
  color: #fff !important;
  border-radius: 44rpx;
  font-size: 34rpx;
  font-weight: bold;
  margin-top: 20rpx;
  border: none;
  padding: 0;
}

.save-btn::after {
  border: none;
}
