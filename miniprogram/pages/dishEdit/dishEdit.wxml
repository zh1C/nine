<!--pages/dishEdit/dishEdit.wxml-->
<view class="dish-edit-page">
  <!-- 菜品图片 -->
  <view class="card">
    <view class="section-title">菜品图片</view>
    <view class="image-upload" bindtap="chooseImage">
      <image
        wx:if="{{imageTempPath || imageFileID}}"
        class="preview-image"
        src="{{imageTempPath || imageFileID}}"
        mode="aspectFill"
      />
      <view wx:else class="upload-placeholder">
        <text class="upload-icon">📷</text>
        <text class="upload-text">点击上传图片</text>
      </view>
    </view>
  </view>

  <!-- 菜品名称 -->
  <view class="card">
    <view class="section-title">菜品名称</view>
    <input
      class="name-input"
      placeholder="请输入菜品名称"
      value="{{name}}"
      bindinput="onInputName"
    />
  </view>

  <!-- 菜品类型 -->
  <view class="card">
    <view class="section-title">菜品类型</view>
    <view class="tip-text">选择该菜品属于学生餐还是老师餐</view>
    <view class="category-selector">
      <view
        class="category-option {{category === 'student' ? 'active' : ''}}"
        bindtap="onSelectCategory"
        data-value="student"
      >
        <text class="category-icon">🎒</text>
        <text class="category-text">学生餐</text>
      </view>
      <view
        class="category-option {{category === 'teacher' ? 'active' : ''}}"
        bindtap="onSelectCategory"
        data-value="teacher"
      >
        <text class="category-icon">👨‍🏫</text>
        <text class="category-text">老师餐</text>
      </view>
    </view>
  </view>

  <!-- 配料列表 -->
  <view class="card">
    <view class="section-title">配料列表</view>
    <view class="tip-text">定义该菜品包含哪些配料</view>

    <view class="ingredient-header">
      <text class="col-name">配料名</text>
      <text class="col-unit">单位</text>
      <text class="col-type">类型</text>
      <text class="col-advance">提前</text>
      <text class="col-reuse">重复</text>
      <text class="col-action">操作</text>
    </view>

    <view wx:for="{{ingredients}}" wx:key="index" class="ingredient-row">
      <input
        class="ingredient-name"
        placeholder="名称"
        value="{{item.name}}"
        data-idx="{{index}}"
        bindinput="onInputIngredientName"
      />
      <picker
        class="ingredient-unit"
        range="{{unitOptions}}"
        value="{{unitOptions.indexOf(item.unit)}}"
        data-idx="{{index}}"
        bindchange="onPickerChange"
      >
        <view class="unit-picker">{{item.unit}} ▼</view>
      </picker>
      <picker
        class="ingredient-type"
        range="{{typeOptions}}"
        value="{{typeOptions.indexOf(item.type)}}"
        data-idx="{{index}}"
        bindchange="onTypePickerChange"
      >
        <view class="type-picker">{{item.type}} ▼</view>
      </picker>
      <view class="advance-check" data-idx="{{index}}" bindtap="toggleAdvance">
        <view class="checkbox {{item.advance ? 'checked' : ''}}">
          <text wx:if="{{item.advance}}">✓</text>
        </view>
      </view>
      <view class="reuse-check" data-idx="{{index}}" bindtap="toggleReuse">
        <view class="checkbox {{item.reuse ? 'checked' : ''}}">
          <text wx:if="{{item.reuse}}">✓</text>
        </view>
      </view>
      <view class="remove-btn" data-idx="{{index}}" bindtap="removeIngredient">✕</view>
    </view>

    <view class="add-ingredient-btn" bindtap="addIngredient">
      <text>+ 添加配料</text>
    </view>
  </view>

  <!-- 各园区配料比例 -->
  <view class="card">
    <view class="section-title">各园区配料比例</view>
    <view class="tip-text">为每个园区设定各配料的比例（不填写则不保存）</view>

    <view wx:if="{{gardens.length === 0}}" class="empty-garden-tip">
      <text>暂无园区数据，请先到「园区管理」中添加园区</text>
    </view>

    <view wx:for="{{gardens}}" wx:key="gardenId" class="garden-section">
      <view class="garden-header" bindtap="toggleGarden" data-idx="{{index}}">
        <view class="garden-header-left">
          <text class="garden-title">{{item.name}}</text>
          <view class="garden-status {{item.filled ? 'status-filled' : 'status-empty'}}">
            <text class="garden-status-text">{{item.filled ? '已填写' : '未填写'}}</text>
          </view>
        </view>
        <text class="garden-arrow">{{item.expanded ? '▲' : '▼'}}</text>
      </view>

      <view class="garden-body" wx:if="{{item.expanded}}">
        <view wx:for="{{ingredients}}" wx:for-item="ing" wx:for-index="ingIdx" wx:key="ingIdx" class="ratio-row">
          <text class="ratio-label">{{ing.name || '配料' + (ingIdx + 1)}}</text>
          <input
            class="ratio-input"
            placeholder="比例"
            type="digit"
            value="{{item.ratios[ingIdx]}}"
            data-garden-idx="{{index}}"
            data-ing-idx="{{ingIdx}}"
            bindinput="onInputRatio"
          />
          <text class="ratio-unit">{{ing.unit}}</text>
          <text class="advance-tag" wx:if="{{ing.advance}}">🚚</text>
          <text class="reuse-tag" wx:if="{{ing.reuse}}">🔄</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <button class="save-btn" bindtap="handleSave" loading="{{loading}}" disabled="{{loading}}">
    {{loading ? '保存中...' : '保存菜品'}}
  </button>

  <!-- 菜品冲突弹框 -->
  <view class="conflict-modal-mask" wx:if="{{showConflictModal}}">
    <view class="conflict-modal" catchtap="">
      <!-- 标题区 -->
      <view class="conflict-header">
        <text class="conflict-icon">{{conflictCanForce ? '⚠️' : '🚫'}}</text>
        <text class="conflict-title">{{conflictCanForce ? '配料比例重复' : '菜品冲突'}}</text>
      </view>

      <!-- 提示文字 -->
      <view class="conflict-desc">
        {{conflictCanForce ? '检测到以下菜品与当前菜品的配料和比例一致，您可以选择仍然保存或返回修改：' : '检测到以下菜品与当前菜品存在名称冲突，请修改后再保存：'}}
      </view>

      <!-- 冲突列表 -->
      <scroll-view class="conflict-list" scroll-y>
        <view wx:for="{{conflictList}}" wx:key="dishId" class="conflict-item">
          <view class="conflict-item-header">
            <text class="conflict-dish-name">{{item.dishName}}</text>
            <view class="conflict-type-tag {{item.type === 'name' ? 'tag-name' : 'tag-ratio'}}">
              {{item.type === 'name' ? '名称重复' : '配料比例重复'}}
            </view>
          </view>
          <text class="conflict-detail">{{item.detail}}</text>

          <!-- 查看详情按钮 -->
          <view class="conflict-toggle" bindtap="toggleConflictDetail" data-idx="{{index}}">
            <text class="conflict-toggle-text">{{item.expanded ? '收起详情' : '查看详情'}}</text>
            <text class="conflict-toggle-arrow">{{item.expanded ? '▲' : '▼'}}</text>
          </view>

          <!-- 冲突菜品详情面板 -->
          <view class="conflict-detail-panel" wx:if="{{item.expanded}}">
            <view class="conflict-section-title">📋 配料列表</view>
            <view class="conflict-ing-list">
              <view wx:for="{{item.ingredients}}" wx:for-item="ing" wx:key="name" class="conflict-ing-row">
                <text class="conflict-ing-name">{{ing.name}}</text>
                <text class="conflict-ing-unit">{{ing.unit}}</text>
                <text class="conflict-ing-type">{{ing.type}}</text>
                <text class="conflict-ing-tag" wx:if="{{ing.advance}}">🚚提前</text>
                <text class="conflict-ing-tag" wx:if="{{ing.reuse}}">🔄重复</text>
              </view>
            </view>

            <view class="conflict-section-title">📊 各园区比例</view>
            <view wx:for="{{gardens}}" wx:for-item="garden" wx:key="gardenId">
              <view wx:if="{{item.ratios['' + garden.gardenId]}}" class="conflict-garden-block">
                <text class="conflict-garden-name">{{garden.name}}</text>
                <view class="conflict-ratio-list">
                  <view wx:for="{{item.ingredients}}" wx:for-item="ing" wx:for-index="ingIdx" wx:key="name" class="conflict-ratio-item">
                    <text class="conflict-ratio-label">{{ing.name}}:</text>
                    <text class="conflict-ratio-value">{{item.ratios['' + garden.gardenId][ingIdx]}} {{ing.unit}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- 操作按钮：名称重复只有「我知道了」，仅配料重复有「返回修改」+「仍然保存」 -->
      <view class="conflict-actions" wx:if="{{!conflictCanForce}}">
        <view class="conflict-btn conflict-btn-block" bindtap="onCloseConflictModal">
          我知道了
        </view>
      </view>
      <view class="conflict-actions" wx:else>
        <view class="conflict-btn conflict-btn-cancel" bindtap="onCloseConflictModal">
          返回修改
        </view>
        <view class="conflict-btn conflict-btn-force" bindtap="onConflictForce">
          仍然保存
        </view>
      </view>
    </view>
  </view>
</view>
