<!--pages/dishEdit/dishEdit.wxml-->
<view class="dish-edit-page">
  <!-- иҸңе“ҒеӣҫзүҮ -->
  <view class="card">
    <view class="section-title">иҸңе“ҒеӣҫзүҮ</view>
    <view class="image-upload" bindtap="chooseImage">
      <image
        wx:if="{{imageTempPath || imageFileID}}"
        class="preview-image"
        src="{{imageTempPath || imageFileID}}"
        mode="aspectFill"
      />
      <view wx:else class="upload-placeholder">
        <text class="upload-icon">рҹ“·</text>
        <text class="upload-text">зӮ№еҮ»дёҠдј еӣҫзүҮ</text>
      </view>
    </view>
  </view>

  <!-- иҸңе“ҒеҗҚз§° -->
  <view class="card">
    <view class="section-title">иҸңе“ҒеҗҚз§°</view>
    <input
      class="name-input"
      placeholder="иҜ·иҫ“е…ҘиҸңе“ҒеҗҚз§°"
      value="{{name}}"
      bindinput="onInputName"
    />
  </view>

  <!-- иҸңе“Ғзұ»еһӢ -->
  <view class="card">
    <view class="section-title">иҸңе“Ғзұ»еһӢ</view>
    <view class="tip-text">йҖүжӢ©иҜҘиҸңе“ҒеұһдәҺеӯҰз”ҹйӨҗиҝҳжҳҜиҖҒеёҲйӨҗ</view>
    <view class="category-selector">
      <view
        class="category-option {{category === 'student' ? 'active' : ''}}"
        bindtap="onSelectCategory"
        data-value="student"
      >
        <text class="category-icon">рҹҺ’</text>
        <text class="category-text">еӯҰз”ҹйӨҗ</text>
      </view>
      <view
        class="category-option {{category === 'teacher' ? 'active' : ''}}"
        bindtap="onSelectCategory"
        data-value="teacher"
      >
        <text class="category-icon">рҹ‘ЁвҖҚрҹҸ«</text>
        <text class="category-text">иҖҒеёҲйӨҗ</text>
      </view>
    </view>
  </view>

  <!-- й…Қж–ҷеҲ—иЎЁ -->
  <view class="card">
    <view class="section-title">й…Қж–ҷеҲ—иЎЁ</view>
    <view class="tip-text">е®ҡд№үиҜҘиҸңе“ҒеҢ…еҗ«е“Әдәӣй…Қж–ҷ</view>

    <view class="ingredient-header">
      <text class="col-name">й…Қж–ҷеҗҚ</text>
      <text class="col-unit">еҚ•дҪҚ</text>
      <text class="col-type">зұ»еһӢ</text>
      <text class="col-advance">жҸҗеүҚ</text>
      <text class="col-reuse">йҮҚеӨҚ</text>
      <text class="col-action">ж“ҚдҪң</text>
    </view>

    <view wx:for="{{ingredients}}" wx:key="index" class="ingredient-row">
      <input
        class="ingredient-name"
        placeholder="еҗҚз§°"
        value="{{item.name}}"
        data-idx="{{index}}"
        bindinput="onInputIngredientName"
      />
      <picker
        class="ingredient-unit"
        range="{{unitOptions}}"
        value="{{unitOptions.indexOf(item.unit)}}"
        data-idx="{{index}}"
        bindchange="onPickerChange"
      >
        <view class="unit-picker">{{item.unit}} в–ј</view>
      </picker>
      <picker
        class="ingredient-type"
        range="{{typeOptions}}"
        value="{{typeOptions.indexOf(item.type)}}"
        data-idx="{{index}}"
        bindchange="onTypePickerChange"
      >
        <view class="type-picker">{{item.type}} в–ј</view>
      </picker>
      <view class="advance-check" data-idx="{{index}}" bindtap="toggleAdvance">
        <view class="checkbox {{item.advance ? 'checked' : ''}}">
          <text wx:if="{{item.advance}}">вң“</text>
        </view>
      </view>
      <view class="reuse-check" data-idx="{{index}}" bindtap="toggleReuse">
        <view class="checkbox {{item.reuse ? 'checked' : ''}}">
          <text wx:if="{{item.reuse}}">вң“</text>
        </view>
      </view>
      <view class="remove-btn" data-idx="{{index}}" bindtap="removeIngredient">вң•</view>
    </view>

    <view class="add-ingredient-btn" bindtap="addIngredient">
      <text>+ ж·»еҠ й…Қж–ҷ</text>
    </view>
  </view>

  <!-- еҗ„еӣӯеҢәй…Қж–ҷжҜ”дҫӢ -->
  <view class="card">
    <view class="section-title">еҗ„еӣӯеҢәй…Қж–ҷжҜ”дҫӢ</view>
    <view class="tip-text">дёәжҜҸдёӘеӣӯеҢәи®ҫе®ҡеҗ„й…Қж–ҷзҡ„жҜ”дҫӢпјҲдёҚеЎ«еҶҷеҲҷдёҚдҝқеӯҳпјү</view>

    <view wx:if="{{gardens.length === 0}}" class="empty-garden-tip">
      <text>жҡӮж— еӣӯеҢәж•°жҚ®пјҢиҜ·е…ҲеҲ°гҖҢеӣӯеҢәз®ЎзҗҶгҖҚдёӯж·»еҠ еӣӯеҢә</text>
    </view>

    <view wx:for="{{gardens}}" wx:key="gardenId" class="garden-section">
      <view class="garden-header" bindtap="toggleGarden" data-idx="{{index}}">
        <view class="garden-header-left">
          <text class="garden-title">{{item.name}}</text>
          <view class="garden-status {{item.filled ? 'status-filled' : 'status-empty'}}">
            <text class="garden-status-text">{{item.filled ? 'е·ІеЎ«еҶҷ' : 'жңӘеЎ«еҶҷ'}}</text>
          </view>
        </view>
        <text class="garden-arrow">{{item.expanded ? 'в–І' : 'в–ј'}}</text>
      </view>

      <view class="garden-body" wx:if="{{item.expanded}}">
        <view wx:for="{{ingredients}}" wx:for-item="ing" wx:for-index="ingIdx" wx:key="ingIdx" class="ratio-row">
          <text class="ratio-label">{{ing.name || 'й…Қж–ҷ' + (ingIdx + 1)}}</text>
          <input
            class="ratio-input"
            placeholder="жҜ”дҫӢ"
            type="digit"
            value="{{item.ratios[ingIdx]}}"
            data-garden-idx="{{index}}"
            data-ing-idx="{{ingIdx}}"
            bindinput="onInputRatio"
          />
          <text class="ratio-unit">{{ing.unit}}</text>
          <text class="advance-tag" wx:if="{{ing.advance}}">рҹҡҡ</text>
          <text class="reuse-tag" wx:if="{{ing.reuse}}">рҹ”„</text>
        </view>
      </view>
    </view>
  </view>

  <!-- дҝқеӯҳжҢүй’® -->
  <button class="save-btn" bindtap="handleSave" loading="{{loading}}" disabled="{{loading}}">
    {{loading ? 'дҝқеӯҳдёӯ...' : 'дҝқеӯҳиҸңе“Ғ'}}
  </button>

  <!-- иҸңе“ҒеҶІзӘҒеј№жЎҶ -->
  <view class="conflict-modal-mask" wx:if="{{showConflictModal}}">
    <view class="conflict-modal" catchtap="">
      <!-- ж ҮйўҳеҢә -->
      <view class="conflict-header">
        <text class="conflict-icon">{{conflictCanForce ? 'вҡ пёҸ' : 'рҹҡ«'}}</text>
        <text class="conflict-title">{{conflictCanForce ? 'й…Қж–ҷжҜ”дҫӢйҮҚеӨҚ' : 'иҸңе“ҒеҶІзӘҒ'}}</text>
      </view>

      <!-- жҸҗзӨәж–Үеӯ— -->
      <view class="conflict-desc">
        {{conflictCanForce ? 'жЈҖжөӢеҲ°д»ҘдёӢиҸңе“ҒдёҺеҪ“еүҚиҸңе“Ғзҡ„й…Қж–ҷе’ҢжҜ”дҫӢдёҖиҮҙпјҢжӮЁеҸҜд»ҘйҖүжӢ©д»Қз„¶дҝқеӯҳжҲ–иҝ”еӣһдҝ®ж”№пјҡ' : 'жЈҖжөӢеҲ°д»ҘдёӢиҸңе“ҒдёҺеҪ“еүҚиҸңе“ҒеӯҳеңЁеҗҚз§°еҶІзӘҒпјҢиҜ·дҝ®ж”№еҗҺеҶҚдҝқеӯҳпјҡ'}}
      </view>

      <!-- еҶІзӘҒеҲ—иЎЁ -->
      <scroll-view class="conflict-list" scroll-y>
        <view wx:for="{{conflictList}}" wx:key="dishId" class="conflict-item">
          <view class="conflict-item-header">
            <text class="conflict-dish-name">{{item.dishName}}</text>
            <view class="conflict-type-tag {{item.type === 'name' ? 'tag-name' : 'tag-ratio'}}">
              {{item.type === 'name' ? 'еҗҚз§°йҮҚеӨҚ' : 'й…Қж–ҷжҜ”дҫӢйҮҚеӨҚ'}}
            </view>
          </view>
          <text class="conflict-detail">{{item.detail}}</text>
        </view>
      </scroll-view>

      <!-- ж“ҚдҪңжҢүй’®пјҡеҗҚз§°йҮҚеӨҚеҸӘжңүгҖҢжҲ‘зҹҘйҒ“дәҶгҖҚпјҢд»…й…Қж–ҷйҮҚеӨҚжңүгҖҢиҝ”еӣһдҝ®ж”№гҖҚ+гҖҢд»Қз„¶дҝқеӯҳгҖҚ -->
      <view class="conflict-actions" wx:if="{{!conflictCanForce}}">
        <view class="conflict-btn conflict-btn-block" bindtap="onCloseConflictModal">
          жҲ‘зҹҘйҒ“дәҶ
        </view>
      </view>
      <view class="conflict-actions" wx:else>
        <view class="conflict-btn conflict-btn-cancel" bindtap="onCloseConflictModal">
          иҝ”еӣһдҝ®ж”№
        </view>
        <view class="conflict-btn conflict-btn-force" bindtap="onConflictForce">
          д»Қз„¶дҝқеӯҳ
        </view>
      </view>
    </view>
  </view>
</view>
