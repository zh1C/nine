<!--pages/calculate/calculate.wxml-->
<view class="calculate-page">
  <!-- 页面加载中 -->
  <view wx:if="{{pageLoading}}" class="page-loading">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载数据中...</text>
  </view>

  <!-- 加载失败 -->
  <view wx:elif="{{loadError}}" class="page-error">
    <text class="error-icon">⚠️</text>
    <text class="error-text">数据加载失败，请重试</text>
    <view class="retry-btn" bindtap="retryLoad">重新加载</view>
  </view>

  <!-- 主内容 -->
  <block wx:else>
  <!-- 日期选择 -->
  <view class="card">
    <view class="section-title">📅 选择下单日期</view>

    <!-- 月份切换 -->
    <view class="calendar-nav">
      <view class="nav-btn" bindtap="prevMonth">◀</view>
      <text class="nav-title">{{currentYear}}年{{currentMonth}}月</text>
      <view class="nav-btn" bindtap="nextMonth">▶</view>
    </view>

    <!-- 星期表头 -->
    <view class="calendar-week">
      <text wx:for="{{weekDays}}" wx:key="*this" class="week-cell">{{item}}</text>
    </view>

    <!-- 日期网格 -->
    <view class="calendar-grid">
      <view
        wx:for="{{calendarDays}}"
        wx:key="date"
        class="day-cell {{item.empty ? 'empty' : ''}} {{item.selected ? 'selected' : ''}}"
        bindtap="toggleDate"
        data-date="{{item.date}}"
      >
        <text wx:if="{{!item.empty}}" class="day-text">{{item.day}}</text>
      </view>
    </view>

    <!-- 快捷选择 -->
    <view class="quick-btns">
      <view class="quick-btn" bindtap="selectThisWeek">本周剩余</view>
      <view class="quick-btn" bindtap="selectNextWeek">下周一至五</view>
    </view>

    <!-- 已选日期 -->
    <view wx:if="{{selectedDates.length > 0}}" class="selected-dates">
      <text class="selected-label">已选 {{selectedDates.length}} 天</text>
    </view>
  </view>

  <!-- 每日菜品选择 -->
  <view class="card" wx:if="{{selectedDates.length > 0}}">
    <view class="section-title">🥘 选择每日菜品</view>

    <!-- 日期Tab -->
    <scroll-view class="date-tabs" scroll-x>
      <view
        wx:for="{{dateTabList}}"
        wx:key="date"
        class="date-tab {{currentDateIdx === index ? 'active' : ''}}"
        data-idx="{{index}}"
        bindtap="switchDateTab"
      >
        <text class="tab-text">{{item.label}}</text>
        <!-- 已选菜品小绿点 -->
        <view wx:if="{{item.dishCount > 0}}" class="tab-badge"></view>
        <!-- 未选菜品小黄点 -->
        <view wx:elif="{{item.dishCount === 0}}" class="tab-dot"></view>
      </view>
    </scroll-view>

    <!-- 学生/老师 子Tab -->
    <view class="sub-tabs">
      <view
        class="sub-tab {{dailySubTab === 'student' ? 'active' : ''}}"
        bindtap="switchSubTab"
        data-tab="student"
      >
        <text class="sub-tab-text">🎒 学生菜品</text>
        <view wx:if="{{studentDishCount > 0}}" class="sub-badge">{{studentDishCount}}</view>
      </view>
      <view
        class="sub-tab {{dailySubTab === 'teacher' ? 'active' : ''}}"
        bindtap="switchSubTab"
        data-tab="teacher"
      >
        <text class="sub-tab-text">👨‍🏫 老师菜品</text>
        <view wx:if="{{teacherDishCount > 0}}" class="sub-badge">{{teacherDishCount}}</view>
      </view>
    </view>

    <!-- 当天当前类型已选菜品列表 -->
    <view class="daily-dishes">
      <block wx:if="{{currentCategoryDishes.length > 0}}">
        <view
          wx:for="{{currentCategoryDishes}}"
          wx:key="_id"
          class="dish-item"
        >
          <view class="dish-item-info">
            <image
              wx:if="{{item.imageFileID}}"
              class="dish-item-image"
              src="{{item.imageFileID}}"
              mode="aspectFill"
            />
            <view wx:else class="dish-item-placeholder">🍽️</view>
            <view class="dish-item-text">
              <text class="dish-item-name">{{item.name}}</text>
              <text class="dish-item-summary">{{item.summary}}</text>
            </view>
          </view>
          <view class="dish-item-actions">
            <view class="dish-detail-btn" data-idx="{{index}}" bindtap="showDishDetail">详情</view>
            <view class="dish-item-remove" data-idx="{{index}}" bindtap="removeDailyDish">✕</view>
          </view>
        </view>
      </block>
      <view wx:else class="empty-daily">
        <text class="empty-text">{{dailySubTab === 'student' ? '学生' : '老师'}}当天未选择菜品</text>
      </view>
    </view>

    <!-- 添加菜品按钮 -->
    <view class="add-dish-btn" bindtap="showDishPicker">
      <text>+ 添加{{dailySubTab === 'student' ? '学生' : '老师'}}菜品（可搜索）</text>
    </view>
  </view>

  <!-- 计算按钮 -->
  <button class="calculate-btn" bindtap="handleCalculate" wx:if="{{selectedDates.length > 0}}">
    开始计算 →
  </button>
  </block>

  <!-- 菜品选择器 -->
  <dish-picker
    show="{{showPicker}}"
    excludeIds="{{pickerExcludeIds}}"
    allDishes="{{filteredDishes}}"
    bind:add="onPickerAdd"
    bind:close="onPickerClose"
  />

  <!-- 配料详情弹窗 -->
  <view class="detail-mask" wx:if="{{showDetail}}" bindtap="closeDetail">
    <view class="detail-panel" catchtap="preventBubble">
      <view class="detail-handle"></view>

      <!-- 头部 -->
      <view class="detail-hd">
        <image wx:if="{{detailDish.imageFileID}}" class="detail-img" src="{{detailDish.imageFileID}}" mode="aspectFill" />
        <view wx:else class="detail-img-ph">🍽️</view>
        <text class="detail-name">{{detailDish.name}}</text>
        <view class="detail-tag">{{detailDish.categoryLabel}}</view>
      </view>

      <scroll-view class="detail-body" scroll-y>
        <!-- 配料属性（默认折叠） -->
        <view class="detail-ing-bar" bindtap="toggleDetailIng">
          <text class="detail-ing-title">配料属性（{{detailIngredients.length}}种）</text>
          <text class="detail-ing-arrow">{{detailIngExpanded ? '▲' : '▼'}}</text>
        </view>
        <view class="detail-ing-table" wx:if="{{detailIngExpanded}}">
          <view class="dit-hd">
            <text class="dit-name">配料名</text>
            <text class="dit-unit">单位</text>
            <text class="dit-type">类型</text>
            <text class="dit-adv">提前</text>
            <text class="dit-reuse">重复</text>
          </view>
          <view wx:for="{{detailIngredients}}" wx:key="index" class="dit-row">
            <text class="dit-name">{{item.name}}</text>
            <text class="dit-unit">{{item.unit}}</text>
            <text class="dit-type">{{item.type}}</text>
            <text class="dit-adv">{{item.advance ? '🚚' : '-'}}</text>
            <text class="dit-reuse">{{item.reuse ? '🔄' : '-'}}</text>
          </view>
        </view>

        <!-- 各园区用量（默认全部展开） -->
        <view wx:for="{{detailGardens}}" wx:key="gardenId" class="detail-gd">
          <view class="detail-gd-hd">
            <text class="detail-gd-name">{{item.name}}</text>
            <view class="detail-gd-st {{item.filled ? 'gd-ok' : 'gd-warn'}}">
              <text>{{item.filled ? '已配' : '未配'}}</text>
            </view>
          </view>
          <!-- 已配园区：两列紧凑展示 -->
          <view class="detail-gd-grid" wx:if="{{item.filled}}">
            <view wx:for="{{detailIngredients}}" wx:for-item="ing" wx:for-index="ii" wx:key="ii" class="detail-gd-cell">
              <text class="gd-cell-name">{{ing.name}}</text>
              <text class="gd-cell-val">{{item.ratios[ii] || '-'}} {{ing.unit}}</text>
              <text class="gd-cell-adv" wx:if="{{ing.advance}}">🚚</text>
              <text class="gd-cell-reuse" wx:if="{{ing.reuse}}">🔄</text>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="detail-close" bindtap="closeDetail">关闭</view>
    </view>
  </view>
</view>
