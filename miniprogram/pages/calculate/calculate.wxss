/* pages/calculate/calculate.wxss */
.calculate-page {
  min-height: 100vh;
  padding: 20rpx 30rpx 40rpx;
  background: #f5f5f5;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.garden-input {
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  background: #fafafa;
}

.empty-dishes {
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.dish-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.dish-row-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.dish-row-image {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.dish-row-placeholder {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.dish-row-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.dish-row-quantity {
  display: flex;
  align-items: center;
}

.quantity-input {
  width: 120rpx;
  height: 56rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  text-align: center;
  font-size: 26rpx;
  background: #fafafa;
}

.quantity-unit {
  font-size: 24rpx;
  color: #666;
  margin-left: 8rpx;
}

.dish-remove {
  margin-left: 16rpx;
  color: #FF5252;
  font-size: 28rpx;
  padding: 8rpx;
}

.add-dish-btn {
  margin-top: 20rpx;
  text-align: center;
  padding: 24rpx;
  border: 1rpx dashed #4CAF50;
  border-radius: 8rpx;
  color: #4CAF50;
  font-size: 28rpx;
}

.calculate-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #FF9800 !important;
  color: #fff !important;
  border-radius: 44rpx;
  font-size: 34rpx;
  font-weight: bold;
  margin-top: 20rpx;
  border: none;
}

.calculate-btn::after {
  border: none;
}
