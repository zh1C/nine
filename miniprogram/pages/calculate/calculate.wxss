/* pages/calculate/calculate.wxss */
.calculate-page {
  min-height: 100vh;
  padding: 20rpx 30rpx 40rpx;
  background: #f5f5f5;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 日历 */
.calendar-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 50%;
}

.nav-btn:active {
  background: #e0e0e0;
}

.nav-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.calendar-week {
  display: flex;
  margin-bottom: 12rpx;
}

.week-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 0;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-cell {
  width: calc(100% / 7);
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.day-text {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 50%;
}

.day-cell.empty {
  pointer-events: none;
}

.day-cell.selected .day-text {
  background: #4CAF50;
  color: #fff;
  font-weight: bold;
}

.day-cell:active:not(.empty):not(.selected) .day-text {
  background: #e8f5e9;
}

/* 快捷按钮 */
.quick-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.quick-btn {
  flex: 1;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8f5e9;
  color: #4CAF50;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.quick-btn:active {
  opacity: 0.7;
}

/* 已选日期 */
.selected-dates {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.selected-label {
  font-size: 26rpx;
  color: #4CAF50;
  font-weight: bold;
}

/* 日期Tab */
.date-tabs {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.date-tab {
  display: inline-flex;
  align-items: center;
  position: relative;
  padding: 12rpx 20rpx;
  padding-right: 36rpx;
  margin-right: 12rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  min-width: 140rpx;
  box-sizing: border-box;
}

.date-tab.active {
  background: #4CAF50;
  color: #fff;
  font-weight: bold;
}

.tab-text {
  font-size: 26rpx;
  margin-right: 4rpx;
}

/* 小圆点 - 已选菜品（红点） */
.tab-badge {
  position: absolute;
  top: 50%;
  right: 12rpx;
  transform: translateY(-50%);
  width: 16rpx;
  height: 16rpx;
  background: #FF5252;
  border-radius: 50%;
}

/* 小圆点 - 未选菜品（黄点） */
.tab-dot {
  position: absolute;
  top: 50%;
  right: 12rpx;
  transform: translateY(-50%);
  width: 16rpx;
  height: 16rpx;
  background: #FF9800;
  border-radius: 50%;
}

/* 学生/老师 子Tab */
.sub-tabs {
  display: flex;
  margin: 20rpx 0 16rpx;
  border-bottom: 2rpx solid #eee;
}

.sub-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #999;
  position: relative;
  transition: all 0.2s;
}

.sub-tab.active {
  color: #4CAF50;
  font-weight: bold;
  border-bottom: 4rpx solid #4CAF50;
}

.sub-tab-text {
  line-height: 1;
}

.sub-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
  background: #FF5722;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  border-radius: 16rpx;
  text-align: center;
  padding: 0 6rpx;
}

/* 每日菜品列表 */
.daily-dishes {
  margin-bottom: 20rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.dish-item:last-child {
  border-bottom: none;
}

.dish-item-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.dish-item-image {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.dish-item-placeholder {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.dish-item-text {
  display: flex;
  flex-direction: column;
}

.dish-item-name {
  font-size: 28rpx;
  color: #333;
}

.dish-item-summary {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.dish-item-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.dish-detail-btn {
  font-size: 22rpx;
  color: #4CAF50;
  border: 1rpx solid #4CAF50;
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
}

.dish-detail-btn:active {
  opacity: 0.7;
}

.dish-item-remove {
  color: #FF5252;
  font-size: 28rpx;
  padding: 8rpx 12rpx;
}

.empty-daily {
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.add-dish-btn {
  text-align: center;
  padding: 24rpx;
  border: 1rpx dashed #4CAF50;
  border-radius: 8rpx;
  color: #4CAF50;
  font-size: 28rpx;
}

.add-dish-btn:active {
  opacity: 0.7;
}

/* 计算按钮 */
.calculate-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FF9800 !important;
  color: #fff !important;
  border-radius: 44rpx;
  font-size: 34rpx;
  font-weight: bold;
  margin-top: 20rpx;
  border: none;
  padding: 0;
}

.calculate-btn::after {
  border: none;
}

/* 页面 Loading 状态 */
.page-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

/* 加载错误状态 */
.page-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.retry-btn {
  padding: 16rpx 48rpx;
  background: #4CAF50;
  color: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.retry-btn:active {
  opacity: 0.7;
}

/* ========== 配料详情弹窗 ========== */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.detail-panel {
  width: 100%;
  max-height: 75vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 0 24rpx calc(30rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
}

.detail-handle {
  width: 60rpx;
  height: 6rpx;
  background: #ddd;
  border-radius: 3rpx;
  margin: 16rpx auto 12rpx;
}

/* 头部 */
.detail-hd {
  display: flex;
  align-items: center;
  padding: 10rpx 0 14rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-img {
  width: 60rpx;
  height: 60rpx;
  border-radius: 10rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.detail-img-ph {
  width: 60rpx;
  height: 60rpx;
  border-radius: 10rpx;
  margin-right: 14rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}

.detail-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.detail-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: #e8f5e9;
  color: #388e3c;
  border-radius: 8rpx;
  flex-shrink: 0;
}

/* 滚动体 */
.detail-body {
  flex: 1;
  overflow-y: auto;
}

/* 配料属性折叠栏 */
.detail-ing-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-ing-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.detail-ing-arrow {
  font-size: 22rpx;
  color: #999;
}

/* 配料属性表格 */
.detail-ing-table {
  padding: 8rpx 0 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dit-hd {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #e8e8e8;
}

.dit-hd text {
  font-size: 22rpx;
  color: #999;
}

.dit-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.dit-row:last-child {
  border-bottom: none;
}

.dit-row text {
  font-size: 24rpx;
  color: #333;
}

.dit-name {
  flex: 3;
}

.dit-unit {
  flex: 2;
  color: #666;
}

.dit-type {
  flex: 2;
  color: #666;
}

.dit-adv {
  width: 60rpx;
  text-align: center;
}

.dit-reuse {
  width: 60rpx;
  text-align: center;
}

/* 园区用量区域 */
.detail-gd {
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-gd:last-child {
  border-bottom: none;
}

.detail-gd-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
}

.detail-gd-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.detail-gd-st {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.gd-ok {
  background: #e8f5e9;
  color: #388e3c;
}

.gd-warn {
  background: #fff8e1;
  color: #f57c00;
}

/* 园区配料网格（两列） */
.detail-gd-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 0 10rpx;
}

.detail-gd-cell {
  width: 50%;
  display: flex;
  align-items: center;
  padding: 6rpx 0;
  box-sizing: border-box;
}

.gd-cell-name {
  font-size: 24rpx;
  color: #666;
  width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.gd-cell-val {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  margin-left: 8rpx;
}

.gd-cell-adv {
  font-size: 20rpx;
  margin-left: 4rpx;
}

.gd-cell-reuse {
  font-size: 20rpx;
  margin-left: 2rpx;
}

/* 关闭按钮 */
.detail-close {
  margin-top: 16rpx;
  text-align: center;
  padding: 16rpx 0;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.detail-close:active {
  background: #e8e8e8;
}
