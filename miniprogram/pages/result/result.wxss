/* pages/result/result.wxss */
.result-page {
  min-height: 100vh;
  padding: 20rpx 30rpx 40rpx;
  background: #f5f5f5;
}

/* 表格卡片 */
.table-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.table-card-header {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  padding: 24rpx 30rpx;
}

.summary-header {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
}

.table-card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

/* 表格 */
.table-wrapper {
  padding: 0;
}

.table-scroll {
  width: 100%;
}

.table-inner {
  min-width: 100%;
  display: inline-block;
}

.table-header-row {
  display: flex;
  background: #f5f5f5;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e8e8e8;
}

.table-data-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.table-data-row.even {
  background: #fafafa;
}

.table-data-row:last-child {
  border-bottom: none;
}

.th {
  font-size: 24rpx;
  color: #666;
  font-weight: bold;
  text-align: center;
  padding: 0 8rpx;
}

.th-name {
  min-width: 160rpx;
  text-align: left;
  padding-left: 24rpx;
}

.th-garden {
  min-width: 140rpx;
}

.th-unit {
  min-width: 80rpx;
}

.th-date {
  min-width: 160rpx;
  text-align: left;
  padding-left: 24rpx;
}

.th-garden-wide {
  min-width: 180rpx;
}

.td {
  font-size: 26rpx;
  text-align: center;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.td-name {
  min-width: 160rpx;
  text-align: left;
  padding-left: 24rpx;
  color: #333;
  justify-content: flex-start;
}

.td-amount {
  min-width: 140rpx;
  color: #ccc;
}

.td-amount.has-value {
  color: #FF9800;
  font-weight: bold;
}

.td-unit {
  min-width: 80rpx;
  color: #666;
}

.td-date {
  min-width: 160rpx;
  text-align: left;
  padding-left: 24rpx;
  color: #333;
  font-weight: bold;
  justify-content: flex-start;
}

.td-dishes {
  min-width: 180rpx;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 8rpx;
}

.dish-tag {
  font-size: 22rpx;
  color: #333;
  background: #e8f5e9;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin: 2rpx 0;
  display: inline-block;
}

.no-dish {
  font-size: 24rpx;
  color: #ccc;
}

/* 保存按钮 */
.table-save-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  color: #2196F3;
  font-size: 26rpx;
}

.table-save-btn:active {
  background: #f5f5f5;
}

/* 底部操作 */
.bottom-actions {
  margin-top: 20rpx;
  padding-bottom: 40rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  padding: 0;
}

.action-btn::after {
  border: none;
}

.save-record-btn {
  background-color: #FF9800 !important;
  color: #fff !important;
}
