/* pages/result/result.wxss */
.result-page {
  min-height: 100vh;
  padding: 20rpx 30rpx 40rpx;
  background: #f5f5f5;
}

.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 0;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 24rpx;
}

.result-header {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
}

.garden-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.result-date {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.result-section {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-section:last-child {
  border-bottom: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.table {
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid #e8e8e8;
}

.table-header {
  display: flex;
  background: #f5f5f5;
  padding: 20rpx 16rpx;
}

.th {
  font-size: 24rpx;
  color: #666;
  font-weight: bold;
}

.th-name {
  flex: 3;
}

.th-amount {
  flex: 2;
  text-align: center;
}

.th-unit {
  flex: 1;
  text-align: center;
}

.table-row {
  display: flex;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.table-row.even {
  background: #fafafa;
}

.table-row:last-child {
  border-bottom: none;
}

.td {
  font-size: 26rpx;
}

.td-name {
  flex: 3;
  color: #333;
}

.td-amount {
  flex: 2;
  text-align: center;
  color: #FF9800;
  font-weight: bold;
}

.td-unit {
  flex: 1;
  text-align: center;
  color: #666;
}

.item-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.item-row:last-child {
  border-bottom: none;
}

.item-name {
  font-size: 28rpx;
  color: #333;
}

.item-quantity {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: bold;
}

.image-preview {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.result-image {
  width: 100%;
  border-radius: 8rpx;
}

.preview-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.action-btn::after {
  border: none;
}

.generate-btn {
  background-color: #4CAF50 !important;
  color: #fff !important;
}

.save-album-btn {
  background-color: #2196F3 !important;
  color: #fff !important;
}

.save-record-btn {
  background-color: #FF9800 !important;
  color: #fff !important;
}
