<!--pages/result/result.wxml-->
<view class="result-page">
  <!-- 每天的配料表 -->
  <view wx:for="{{tables}}" wx:key="date" class="table-card">
    <view class="table-card-header">
      <text class="table-card-title">📋 {{item.dateLabel}} 配料清单</text>
    </view>

    <view class="table-wrapper">
      <!-- 表头 -->
      <scroll-view class="table-scroll" scroll-x>
        <view class="table-inner">
          <view class="table-header-row">
            <text class="th th-name">配料</text>
            <text wx:for="{{gardens}}" wx:for-item="garden" wx:key="gardenId" class="th th-garden">{{garden.name}}</text>
            <text class="th th-unit">单位</text>
          </view>

          <!-- 数据行 -->
          <view wx:for="{{item.rows}}" wx:for-item="row" wx:for-index="rowIdx" wx:key="name" class="table-data-row {{rowIdx % 2 === 0 ? 'even' : ''}}">
            <text class="td td-name">{{row.name}}</text>
            <text wx:for="{{gardens}}" wx:for-item="garden" wx:key="gardenId" class="td td-amount {{row.amounts[garden.gardenId] > 0 ? 'has-value' : ''}}">{{row.amounts[garden.gardenId] || 0}}</text>
            <text class="td td-unit">{{row.unit}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 保存按钮 -->
    <view class="table-save-btn" data-idx="{{index}}" data-type="daily" bindtap="generateTableImage">
      <text>💾 保存此表为图片</text>
    </view>
  </view>

  <!-- 菜品下单汇总表 -->
  <view class="table-card summary-card">
    <view class="table-card-header summary-header">
      <text class="table-card-title">📋 菜品下单汇总</text>
    </view>

    <view class="table-wrapper">
      <scroll-view class="table-scroll" scroll-x>
        <view class="table-inner">
          <view class="table-header-row">
            <text class="th th-date">日期</text>
            <text wx:for="{{gardens}}" wx:for-item="garden" wx:key="gardenId" class="th th-garden-wide">{{garden.name}}</text>
          </view>

          <view wx:for="{{summary.dates}}" wx:for-item="dateObj" wx:for-index="dIdx" wx:key="date" class="table-data-row {{dIdx % 2 === 0 ? 'even' : ''}}">
            <text class="td td-date">{{dateObj.label}}</text>
            <view wx:for="{{gardens}}" wx:for-item="garden" wx:key="gardenId" class="td td-dishes">
              <!-- 学生菜品分组 -->
              <view wx:if="{{summary.data[dateObj.date][garden.gardenId].student.length > 0}}" class="dish-group student-group">
                <text class="dish-group-label">🎒学生</text>
                <view class="dish-tag-list">
                  <text wx:for="{{summary.data[dateObj.date][garden.gardenId].student}}" wx:for-item="dishName" wx:key="*this" class="dish-tag student-tag">{{dishName}}</text>
                </view>
              </view>
              <!-- 老师菜品分组 -->
              <view wx:if="{{summary.data[dateObj.date][garden.gardenId].teacher.length > 0}}" class="dish-group teacher-group">
                <text class="dish-group-label">👨‍🏫老师</text>
                <view class="dish-tag-list">
                  <text wx:for="{{summary.data[dateObj.date][garden.gardenId].teacher}}" wx:for-item="dishName" wx:key="*this" class="dish-tag teacher-tag">{{dishName}}</text>
                </view>
              </view>
              <!-- 无菜品 -->
              <text wx:if="{{summary.data[dateObj.date][garden.gardenId].student.length === 0 && summary.data[dateObj.date][garden.gardenId].teacher.length === 0}}" class="no-dish">-</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 保存按钮 -->
    <view class="table-save-btn" data-idx="999" data-type="summary" bindtap="generateTableImage">
      <text>💾 保存此表为图片</text>
    </view>
  </view>

  <!-- 底部操作按钮 -->
  <view class="bottom-actions" wx:if="{{!fromHistory}}">
    <button class="action-btn save-record-btn {{saved ? 'saved' : ''}}" bindtap="saveRecord" loading="{{saving}}" disabled="{{saved}}">
      {{saved ? '☁️ 已保存到云端' : '📥 保存记录到云端'}}
    </button>
  </view>
</view>

<!-- Canvas 用于生成图片 (新版 Canvas 2D) -->
<canvas
  type="2d"
  id="resultCanvas"
  style="position:fixed;left:-9999px;top:-9999px;width:800px;height:1200px;"
/>
<!-- 旧版Canvas降级 -->
<canvas
  canvas-id="resultCanvasLegacy"
  style="position:fixed;left:-9999px;top:-9999px;width:800px;height:1200px;"
/>
