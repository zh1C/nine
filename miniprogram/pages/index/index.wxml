<!--pages/index/index.wxml-->
<view class="index-page">
  <view class="header">
    <view class="header-left">
      <view class="header-avatar">
        <image class="header-avatar-img" wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill"></image>
        <view class="header-avatar-default" wx:else>
          <text>{{userInfo.nickname ? userInfo.nickname[0] : (userInfo.username ? userInfo.username[0] : '?')}}</text>
        </view>
      </view>
      <view class="header-info">
        <text class="header-title">9号菜单</text>
        <text class="header-user">欢迎，{{userInfo.nickname || userInfo.username}}</text>
      </view>
    </view>
    <view class="header-right" bindtap="handleLogout">
      <text class="logout-text">退出</text>
    </view>
  </view>

  <view class="menu-grid">
    <!-- 管理员：菜品管理 -->
    <view class="menu-item" wx:if="{{isAdmin}}" bindtap="navigateTo" data-page="/pages/dishes/dishes">
      <view class="menu-icon">🥘</view>
      <text class="menu-title">菜品管理</text>
      <text class="menu-desc">录入和管理菜品配料</text>
    </view>

    <!-- 所有用户：生成配料 -->
    <view class="menu-item" bindtap="navigateTo" data-page="/pages/calculate/calculate">
      <view class="menu-icon">📊</view>
      <text class="menu-title">生成配料</text>
      <text class="menu-desc">计算配料用量</text>
    </view>

    <!-- 所有用户：历史记录 -->
    <view class="menu-item" bindtap="navigateTo" data-page="/pages/history/history">
      <view class="menu-icon">📋</view>
      <text class="menu-title">历史记录</text>
      <text class="menu-desc">查看保存的配料记录</text>
    </view>

    <!-- 管理员：园区管理 -->
    <view class="menu-item" wx:if="{{isAdmin}}" bindtap="navigateTo" data-page="/pages/gardenManage/gardenManage">
      <view class="menu-icon">🏢</view>
      <text class="menu-title">园区管理</text>
      <text class="menu-desc">管理园区信息</text>
    </view>

    <!-- 管理员：用户管理 -->
    <view class="menu-item" wx:if="{{isAdmin}}" bindtap="navigateTo" data-page="/pages/userManage/userManage">
      <view class="menu-icon">👥</view>
      <text class="menu-title">用户管理</text>
      <text class="menu-desc">管理系统用户</text>
    </view>

    <!-- 所有用户：账号设置 -->
    <view class="menu-item" bindtap="navigateTo" data-page="/pages/profile/profile">
      <view class="menu-icon">⚙️</view>
      <text class="menu-title">账号设置</text>
      <text class="menu-desc">修改个人信息</text>
    </view>
  </view>
</view>
