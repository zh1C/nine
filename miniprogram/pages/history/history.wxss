/* pages/history/history.wxss */
.history-page {
  min-height: 100vh;
  padding: 20rpx 30rpx 40rpx;
  background: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 24rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx 16rpx;
}

/* 记录列表 */
.record-list {
  padding-bottom: 20rpx;
}

.record-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.record-card-body {
  padding: 28rpx 30rpx 20rpx;
}

.record-dates,
.record-gardens,
.record-time {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-dates-icon,
.record-gardens-icon,
.record-time-icon {
  font-size: 26rpx;
  margin-right: 12rpx;
}

.record-dates-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.record-gardens-text {
  font-size: 26rpx;
  color: #666;
}

.record-time-text {
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.record-card-actions {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.record-action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 0;
  font-size: 28rpx;
}

.record-action-btn:active {
  background: #f5f5f5;
}

.view-btn {
  color: #4CAF50;
  border-right: 1rpx solid #f0f0f0;
}

.edit-btn {
  color: #1976D2;
  border-right: 1rpx solid #f0f0f0;
}

.delete-btn {
  color: #F44336;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: #999;
}

.load-more-btn {
  display: inline-block;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  color: #4CAF50;
  background: #e8f5e9;
  border-radius: 30rpx;
}

.load-more-btn:active {
  opacity: 0.8;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
