/* pages/login/login.wxss */
.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx 60rpx;
  background: linear-gradient(180deg, #4CAF50 0%, #81C784 40%, #f5f5f5 100%);
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.login-form {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #e0e0e0;
  margin-bottom: 40rpx;
  padding-bottom: 20rpx;
}

.form-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.form-input {
  flex: 1;
  height: 70rpx;
  font-size: 30rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #4CAF50 !important;
  color: #fff !important;
  border-radius: 44rpx;
  font-size: 34rpx;
  font-weight: bold;
  margin-top: 40rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}

.toggle-mode {
  text-align: center;
  margin-top: 40rpx;
  color: #4CAF50;
  font-size: 28rpx;
}
