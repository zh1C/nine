<!--pages/login/login.wxml-->
<view class="login-page">
  <view class="login-header">
    <view class="logo">🍳</view>
    <text class="title">幼儿园配料计算工具</text>
    <text class="subtitle">{{isRegister ? '注册新账号' : '欢迎登录'}}</text>
  </view>

  <view class="login-form">
    <view class="form-item">
      <view class="form-icon">👤</view>
      <input
        class="form-input"
        placeholder="请输入用户名"
        value="{{username}}"
        bindinput="onInputUsername"
      />
    </view>

    <view class="form-item">
      <view class="form-icon">🔒</view>
      <input
        class="form-input"
        placeholder="请输入密码"
        password
        value="{{password}}"
        bindinput="onInputPassword"
      />
    </view>

    <button class="submit-btn" bindtap="handleSubmit" loading="{{loading}}">
      {{isRegister ? '注 册' : '登 录'}}
    </button>

    <view class="toggle-mode" bindtap="toggleMode">
      <text>{{isRegister ? '已有账号？去登录' : '没有账号？去注册'}}</text>
    </view>
  </view>
</view>
