/* pages/userManage/userManage.wxss */
.user-manage-page {
  min-height: 100vh;
  padding: 30rpx;
  background: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.search-btn {
  height: 72rpx;
  padding: 0 30rpx;
  background: #4CAF50;
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-btn {
  height: 72rpx;
  padding: 0 24rpx;
  background: #f0f0f0;
  color: #666;
  font-size: 28rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 用户列表 */
.user-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.user-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-default {
  width: 100%;
  height: 100%;
  background: #e8f5e9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.user-detail {
  flex: 1;
  overflow: hidden;
}

.user-nickname {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-username {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 6rpx;
}

.user-meta {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  gap: 16rpx;
}

.user-role {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.role-user {
  background: #e3f2fd;
  color: #1976d2;
}

.role-admin {
  background: #fce4ec;
  color: #c62828;
}

.user-time {
  font-size: 22rpx;
  color: #bbb;
}

/* 操作区 */
.user-actions {
  flex-shrink: 0;
  margin-left: 20rpx;
}

.delete-btn {
  padding: 12rpx 28rpx;
  background: #ffebee;
  color: #d32f2f;
  font-size: 26rpx;
  border-radius: 30rpx;
}

.admin-badge {
  font-size: 22rpx;
  color: #999;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载中 */
.loading-state {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
